# ===== KKClaw Desktop Pet - 环境变量配置 =====
# 复制本文件为 .env 并填入你的真实值
# 注意: .env 文件不应提交到 Git（已在 .gitignore 中排除）

# Moltbook API Key（用于 scripts/manual-verify.js 和 scripts/quick-engage.js）
# MOLTBOOK_API_KEY=your_moltbook_api_key_here

# SQLite3 可执行文件路径（用于 cc-switch-sync，默认从 PATH 查找）
# SQLITE3_PATH=sqlite3

# Edge TTS 可执行文件路径（默认从 PATH 查找 'edge-tts'）
# EDGE_TTS_PATH=edge-tts
