{
  "id": "cosmic-jellyfish",
  "name": "宇宙水母",
  "version": "1.0.0",
  "author": "kkclaw-community",
  "description": "深空水母主题 — 极光色系流体球，冷调蓝紫青配色，眼睛更圆更大，飘逸空灵感",
  "type": "css-fluid",

  "size": { "width": 72, "height": 72 },

  "shape": {
    "borderRadius": "50%",
    "glassShell": {
      "background": "radial-gradient(circle at 35% 25%, rgba(180,220,255,0.14), rgba(100,140,255,0.03))",
      "boxShadow": "inset -2px -3px 10px rgba(120,180,255,0.12), inset 2px 2px 10px rgba(200,220,255,0.3), 0px 3px 12px rgba(80,120,220,0.12)",
      "border": "1px solid rgba(180,210,255,0.2)",
      "highlightTop": {
        "top": "10%", "left": "20%", "width": "30%", "height": "16%",
        "background": "rgba(200,230,255,0.5)", "blur": "2px", "rotation": "-35deg"
      },
      "highlightBottom": {
        "bottom": "20%", "right": "18%", "width": "14%", "height": "10%",
        "background": "rgba(150,200,255,0.18)", "blur": "2px", "rotation": "30deg"
      }
    }
  },

  "eyes": {
    "count": 2,
    "gap": "14px",
    "default": { "w": 13, "h": 13, "br": "50%" },
    "color": "#e0f0ff",
    "glow": "0 0 10px rgba(140,200,255,0.9), 0 0 24px rgba(100,160,255,0.5)",
    "containerPosition": { "top": "18%", "left": "8%", "width": "84%", "height": "48%" },
    "expressions": {
      "normal":     { "L": { "w": 13, "h": 13, "br": "50%" } },
      "lookLeft":   { "L": { "w": 13, "h": 13, "br": "50%", "tx": -4 } },
      "lookRight":  { "L": { "w": 13, "h": 13, "br": "50%", "tx": 4 } },
      "lookUp":     { "L": { "w": 13, "h": 13, "br": "50%", "ty": -5 } },
      "lookDown":   { "L": { "w": 11, "h": 11, "br": "50%", "ty": 4 } },
      "squint":     { "L": { "w": 14, "h": 5, "br": "50%" } },
      "talking":    { "L": { "w": 12, "h": 14, "br": "50%" } },
      "talkBig":    { "L": { "w": 14, "h": 16, "br": "50%" } },

      "blink":      { "L": { "w": 14, "h": 2, "br": "50%" }, "speed": "snap" },

      "halfBlink":  { "L": { "w": 13, "h": 7, "br": "50%" }, "speed": "fast" },
      "surprised":  { "L": { "w": 16, "h": 16, "br": "50%" }, "speed": "fast" },
      "wow":        { "L": { "w": 18, "h": 18, "br": "50%" }, "speed": "fast" },
      "sparkle":    { "L": { "w": 10, "h": 10, "br": "2px", "rot": 45 }, "speed": "fast" },
      "wink":       { "L": { "w": 14, "h": 5, "br": "50%", "ty": 1 }, "R": { "w": 13, "h": 13, "br": "50%" }, "speed": "fast" },
      "winkR":      { "L": { "w": 13, "h": 13, "br": "50%" }, "R": { "w": 14, "h": 5, "br": "50%", "ty": 1 }, "speed": "fast" },
      "dizzy":      { "L": { "w": 11, "h": 11, "br": "50%", "rot": 30, "tx": -2 }, "R": { "w": 11, "h": 11, "br": "50%", "rot": -30, "tx": 2 }, "speed": "fast" },
      "cross":      { "L": { "w": 11, "h": 3, "br": "2px", "rot": 35 }, "R": { "w": 11, "h": 3, "br": "2px", "rot": -35 }, "speed": "fast" },
      "flattered":  { "L": { "w": 15, "h": 15, "br": "50%", "sy": 1.08 }, "speed": "fast" },
      "nervous":    { "L": { "w": 10, "h": 12, "br": "50%", "ty": 1, "sx": 0.85 }, "speed": "fast" },

      "happy":      { "L": { "w": 15, "h": 7, "br": "50%", "ty": 1 }, "speed": "smooth" },
      "superHappy": { "L": { "w": 17, "h": 5, "br": "50%", "ty": 1, "sx": 1.1 }, "speed": "smooth" },
      "giggle":     { "L": { "w": 14, "h": 6, "br": "50%", "ty": 1, "rot": -10 }, "R": { "w": 14, "h": 6, "br": "50%", "ty": 1, "rot": 10 }, "speed": "smooth" },
      "curious":    { "L": { "w": 10, "h": 12, "br": "50%", "ty": -1 }, "R": { "w": 15, "h": 17, "br": "50%", "ty": -2 }, "speed": "smooth" },
      "thinking":   { "L": { "w": 11, "h": 14, "br": "50%", "ty": -4 }, "speed": "smooth" },
      "hmm":        { "L": { "w": 12, "h": 13, "br": "50%", "ty": -1, "rot": 10 }, "R": { "w": 10, "h": 10, "br": "50%", "rot": -10 }, "speed": "smooth" },
      "sad":        { "L": { "w": 11, "h": 13, "br": "50%", "ty": 3, "sy": 0.85 }, "speed": "smooth" },
      "angry":      { "L": { "w": 13, "h": 10, "br": "3px 50% 50% 3px", "ty": -2, "rot": -15 }, "R": { "w": 13, "h": 10, "br": "50% 3px 3px 50%", "ty": -2, "rot": 15 }, "speed": "smooth" },
      "love":       { "L": { "w": 14, "h": 12, "br": "50% 2px 50% 2px", "rot": 45, "sx": 1.1 }, "speed": "smooth" },
      "smug":       { "L": { "w": 13, "h": 6, "br": "50%", "ty": 1 }, "R": { "w": 10, "h": 13, "br": "50%", "tx": 3 }, "speed": "smooth" },
      "confused":   { "L": { "w": 13, "h": 15, "br": "50%", "ty": -2 }, "R": { "w": 9, "h": 10, "br": "50%", "ty": 2, "rot": 18 }, "speed": "smooth" },
      "softSmile":  { "L": { "w": 14, "h": 8, "br": "50%", "ty": 1 }, "speed": "smooth" },
      "focus":      { "L": { "w": 9, "h": 15, "br": "50%", "ty": -1 }, "speed": "smooth" },
      "pout":       { "L": { "w": 11, "h": 9, "br": "50%", "ty": 2, "sy": 0.8 }, "speed": "smooth" },
      "peekL":      { "L": { "w": 13, "h": 5, "br": "50%", "ty": 1 }, "R": { "w": 11, "h": 14, "br": "50%", "tx": -3 }, "speed": "smooth" },
      "peekR":      { "L": { "w": 11, "h": 14, "br": "50%", "tx": 3 }, "R": { "w": 13, "h": 5, "br": "50%", "ty": 1 }, "speed": "smooth" },
      "mischief":   { "L": { "w": 14, "h": 12, "br": "50%", "rot": -6, "ty": -1 }, "R": { "w": 10, "h": 9, "br": "50%", "rot": 12, "ty": 1 }, "speed": "smooth" },
      "worried":    { "L": { "w": 12, "h": 14, "br": "50%", "ty": 1, "rot": 6 }, "R": { "w": 12, "h": 14, "br": "50%", "ty": 1, "rot": -6 }, "speed": "smooth" },
      "sly":        { "L": { "w": 11, "h": 12, "br": "50%", "tx": 3, "rot": -8 }, "R": { "w": 14, "h": 6, "br": "50%", "tx": 3, "ty": 1 }, "speed": "smooth" },

      "sleepy":     { "L": { "w": 14, "h": 3, "br": "50%", "ty": 2 }, "speed": "slow" },
      "drowsy":     { "L": { "w": 13, "h": 8, "br": "50%", "ty": 1 }, "speed": "slow" },
      "dead":       { "L": { "w": 11, "h": 2, "br": "50%", "ty": 3 }, "speed": "slow" },
      "content":    { "L": { "w": 15, "h": 7, "br": "50%", "ty": 0, "sx": 1.05 }, "speed": "slow" },
      "bliss":      { "L": { "w": 16, "h": 4, "br": "50%", "ty": 1, "sx": 1.1 }, "speed": "slow" },

      "daydream":   { "L": { "w": 15, "h": 16, "br": "50%", "ty": -3, "sx": 0.92 }, "speed": "drift" },
      "blank":      { "L": { "w": 9, "h": 12, "br": "50%" }, "speed": "drift" }
    }
  },

  "decorations": {
    "blush": {
      "enabled": true,
      "color": "rgba(100,160,255,0.2)",
      "size": { "width": 12, "height": 7 },
      "blur": 4,
      "positions": [
        { "top": "60%", "left": "6%" },
        { "top": "60%", "right": "6%" }
      ]
    },
    "bubbles": {
      "enabled": true,
      "items": [
        { "size": 4, "left": "-6px", "top": "55%", "duration": "7s", "delay": "0s" },
        { "size": 3, "right": "-5px", "top": "35%", "duration": "9s", "delay": "3s" },
        { "size": 2, "left": "10px", "top": "20%", "duration": "6s", "delay": "1.5s" }
      ]
    },
    "particles": {
      "colors": ["#88ccff", "#aa88ff", "#66ffee", "#ccddff", "#ffffff", "#7b68ee"],
      "count": 10,
      "distance": { "min": 18, "max": 50 },
      "sizeRange": { "min": 1.5, "max": 4 }
    }
  },

  "moods": {
    "offline": {
      "fluid": "linear-gradient(135deg, #2a2a3e, #1a1a2e)",
      "b1": "radial-gradient(circle at 35% 30%, rgba(60,60,90,0.85), transparent 40%), radial-gradient(circle at 65% 65%, rgba(50,50,80,0.8), transparent 40%)",
      "b2": "radial-gradient(circle at 55% 25%, rgba(70,70,100,0.35), transparent 35%), radial-gradient(circle at 40% 70%, rgba(40,40,70,0.3), transparent 35%)",
      "glow": "0 0 15px rgba(80,80,120,0.15), 0 0 30px rgba(60,60,100,0.05)",
      "eyes": "sleepy", "scale": 0.92, "bounce": 0, "speed": "24s"
    },
    "idle": {
      "fluid": "linear-gradient(135deg, #4a3f8a, #2e4a7a, #1a3a5c)",
      "b1": "radial-gradient(circle at 30% 25%, rgba(100,80,200,0.85), transparent 42%), radial-gradient(circle at 70% 68%, rgba(60,140,220,0.8), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 30%, rgba(80,180,255,0.35), transparent 35%), radial-gradient(circle at 35% 70%, rgba(120,60,200,0.28), transparent 35%)",
      "glow": "0 0 35px rgba(80,120,255,0.25), 0 0 70px rgba(100,80,200,0.12)",
      "eyes": "normal", "scale": 1, "bounce": 0, "speed": "10s"
    },
    "happy": {
      "fluid": "linear-gradient(135deg, #5a4fcf, #3b82f6, #06b6d4)",
      "b1": "radial-gradient(circle at 30% 25%, rgba(90,80,210,0.9), transparent 42%), radial-gradient(circle at 72% 65%, rgba(6,182,212,0.85), transparent 42%)",
      "b2": "radial-gradient(circle at 50% 25%, rgba(100,200,255,0.4), transparent 35%), radial-gradient(circle at 40% 72%, rgba(60,100,220,0.3), transparent 35%)",
      "glow": "0 0 50px rgba(59,130,246,0.35), 0 0 100px rgba(6,182,212,0.18)",
      "eyes": "happy", "scale": 1.06, "bounce": 0.02, "speed": "6s"
    },
    "talking": {
      "fluid": "linear-gradient(135deg, #6366f1, #8b5cf6, #a78bfa)",
      "b1": "radial-gradient(circle at 28% 28%, rgba(99,102,241,0.88), transparent 42%), radial-gradient(circle at 72% 65%, rgba(139,92,246,0.82), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 28%, rgba(167,139,250,0.38), transparent 35%), radial-gradient(circle at 38% 72%, rgba(79,70,229,0.3), transparent 35%)",
      "glow": "0 0 45px rgba(139,92,246,0.35), 0 0 90px rgba(99,102,241,0.18)",
      "eyes": "talking", "scale": 1, "bounce": 0.015, "speed": "5s"
    },
    "thinking": {
      "fluid": "linear-gradient(135deg, #312e81, #4338ca, #1e1b4b)",
      "b1": "radial-gradient(circle at 32% 28%, rgba(67,56,202,0.88), transparent 44%), radial-gradient(circle at 68% 68%, rgba(49,46,129,0.82), transparent 44%)",
      "b2": "radial-gradient(circle at 58% 28%, rgba(99,102,241,0.35), transparent 36%), radial-gradient(circle at 38% 72%, rgba(55,48,163,0.3), transparent 36%)",
      "glow": "0 0 40px rgba(67,56,202,0.3), 0 0 80px rgba(49,46,129,0.15)",
      "eyes": "thinking", "scale": 1, "bounce": 0, "speed": "14s"
    },
    "sleepy": {
      "fluid": "linear-gradient(135deg, #1e1b4b, #2d2660, #1a1640)",
      "b1": "radial-gradient(circle at 30% 30%, rgba(45,38,96,0.85), transparent 42%), radial-gradient(circle at 68% 65%, rgba(55,48,100,0.78), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 25%, rgba(80,70,140,0.3), transparent 35%), radial-gradient(circle at 38% 72%, rgba(35,30,80,0.25), transparent 35%)",
      "glow": "0 0 25px rgba(80,70,160,0.18), 0 0 50px rgba(55,48,130,0.08)",
      "eyes": "sleepy", "scale": 0.96, "bounce": 0, "speed": "20s"
    },
    "surprised": {
      "fluid": "linear-gradient(135deg, #06b6d4, #22d3ee, #67e8f9)",
      "b1": "radial-gradient(circle at 30% 25%, rgba(6,182,212,0.9), transparent 42%), radial-gradient(circle at 70% 68%, rgba(34,211,238,0.85), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 25%, rgba(103,232,249,0.4), transparent 35%), radial-gradient(circle at 38% 72%, rgba(8,145,178,0.3), transparent 35%)",
      "glow": "0 0 55px rgba(34,211,238,0.4), 0 0 110px rgba(6,182,212,0.2)",
      "eyes": "surprised", "scale": 1.07, "bounce": 0, "speed": "4s"
    },
    "sad": {
      "fluid": "linear-gradient(135deg, #1e3a5f, #0c4a6e, #164e63)",
      "b1": "radial-gradient(circle at 30% 30%, rgba(12,74,110,0.88), transparent 42%), radial-gradient(circle at 68% 65%, rgba(22,78,99,0.82), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 28%, rgba(56,189,248,0.3), transparent 35%), radial-gradient(circle at 38% 72%, rgba(7,89,133,0.28), transparent 35%)",
      "glow": "0 0 35px rgba(56,189,248,0.22), 0 0 70px rgba(14,116,144,0.1)",
      "eyes": "sad", "scale": 0.95, "bounce": 0, "speed": "16s"
    },
    "angry": {
      "fluid": "linear-gradient(135deg, #7c3aed, #6d28d9, #4c1d95)",
      "b1": "radial-gradient(circle at 30% 28%, rgba(124,58,237,0.92), transparent 42%), radial-gradient(circle at 70% 68%, rgba(109,40,217,0.88), transparent 42%)",
      "b2": "radial-gradient(circle at 50% 50%, rgba(139,92,246,0.45), transparent 36%), radial-gradient(circle at 35% 70%, rgba(76,29,149,0.38), transparent 36%)",
      "glow": "0 0 55px rgba(124,58,237,0.45), 0 0 110px rgba(109,40,217,0.22)",
      "eyes": "angry", "scale": 1.04, "bounce": 0.01, "speed": "3s"
    },
    "fearful": {
      "fluid": "linear-gradient(135deg, #0e7490, #155e75, #083344)",
      "b1": "radial-gradient(circle at 30% 28%, rgba(14,116,144,0.88), transparent 42%), radial-gradient(circle at 70% 68%, rgba(21,94,117,0.82), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 28%, rgba(103,232,249,0.35), transparent 35%), radial-gradient(circle at 38% 72%, rgba(8,51,68,0.3), transparent 35%)",
      "glow": "0 0 40px rgba(14,116,144,0.3), 0 0 80px rgba(8,51,68,0.15)",
      "eyes": "nervous", "scale": 0.96, "bounce": 0, "speed": "5s"
    },
    "calm": {
      "fluid": "linear-gradient(135deg, #2dd4bf, #14b8a6, #0d9488)",
      "b1": "radial-gradient(circle at 32% 28%, rgba(45,212,191,0.85), transparent 42%), radial-gradient(circle at 68% 68%, rgba(20,184,166,0.8), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 28%, rgba(94,234,212,0.35), transparent 35%), radial-gradient(circle at 38% 72%, rgba(13,148,136,0.28), transparent 35%)",
      "glow": "0 0 40px rgba(45,212,191,0.28), 0 0 80px rgba(13,148,136,0.12)",
      "eyes": "softSmile", "scale": 1, "bounce": 0, "speed": "12s"
    },
    "excited": {
      "fluid": "linear-gradient(135deg, #818cf8, #6366f1, #4f46e5)",
      "b1": "radial-gradient(circle at 28% 25%, rgba(129,140,248,0.92), transparent 42%), radial-gradient(circle at 72% 68%, rgba(99,102,241,0.88), transparent 42%)",
      "b2": "radial-gradient(circle at 50% 50%, rgba(165,180,252,0.42), transparent 36%), radial-gradient(circle at 38% 72%, rgba(79,70,229,0.35), transparent 36%)",
      "glow": "0 0 60px rgba(99,102,241,0.45), 0 0 120px rgba(129,140,248,0.22)",
      "eyes": "superHappy", "scale": 1.09, "bounce": 0.03, "speed": "3s"
    },
    "love": {
      "fluid": "linear-gradient(135deg, #a78bfa, #8b5cf6, #c084fc)",
      "b1": "radial-gradient(circle at 30% 25%, rgba(167,139,250,0.88), transparent 42%), radial-gradient(circle at 70% 68%, rgba(192,132,252,0.82), transparent 42%)",
      "b2": "radial-gradient(circle at 50% 50%, rgba(196,181,253,0.4), transparent 36%), radial-gradient(circle at 38% 72%, rgba(139,92,246,0.3), transparent 36%)",
      "glow": "0 0 50px rgba(167,139,250,0.38), 0 0 100px rgba(192,132,252,0.18)",
      "eyes": "love", "scale": 1.05, "bounce": 0.018, "speed": "7s"
    },
    "focused": {
      "fluid": "linear-gradient(135deg, #0284c7, #0369a1, #075985)",
      "b1": "radial-gradient(circle at 30% 28%, rgba(2,132,199,0.88), transparent 42%), radial-gradient(circle at 70% 68%, rgba(3,105,161,0.82), transparent 42%)",
      "b2": "radial-gradient(circle at 55% 28%, rgba(56,189,248,0.35), transparent 35%), radial-gradient(circle at 38% 72%, rgba(7,89,133,0.3), transparent 35%)",
      "glow": "0 0 40px rgba(2,132,199,0.32), 0 0 80px rgba(3,105,161,0.15)",
      "eyes": "focus", "scale": 1.02, "bounce": 0, "speed": "10s"
    }
  },

  "animation": {
    "float": {
      "frequencies": [0.8, 0.45, 1.6],
      "amplitudes": [4.5, 2.5, 0.8]
    },
    "rotation": {
      "frequencies": [0.55, 0.25],
      "amplitudes": [0.5, 0.3]
    },
    "breath": {
      "frequency": 1.4,
      "amplitude": 0.015,
      "secondaryFreq": 0.5,
      "secondaryAmp": 0.008
    },
    "fidget": {
      "xFreq": 0.15,
      "xAmp": 0.8,
      "rotFreq": 0.11,
      "rotAmp": 0.15
    },
    "deepBreath": {
      "amplitude": 0.035,
      "speed": 0.03
    }
  }
}
