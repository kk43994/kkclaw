{
  "id": "fluid-lobster",
  "name": "流体龙虾球",
  "version": "1.0.0",
  "author": "kk43994",
  "description": "KKClaw 默认主题 — 琉璃质感流体球，14 情绪配色 + 40+ 眼睛表情",
  "type": "css-fluid",

  "size": { "width": 67, "height": 67 },

  "shape": {
    "borderRadius": "50%",
    "glassShell": {
      "background": "radial-gradient(circle at 30% 30%, rgba(255,255,255,0.12), rgba(255,255,255,0.03))",
      "boxShadow": "inset -2px -2px 8px rgba(255,255,255,0.08), inset 2px 2px 8px rgba(255,255,255,0.35), 0px 2px 6px rgba(220,80,80,0.08)",
      "border": "1px solid rgba(255,255,255,0.25)",
      "highlightTop": {
        "top": "12%", "left": "18%", "width": "28%", "height": "14%",
        "background": "rgba(255,255,255,0.55)", "blur": "1px", "rotation": "-40deg"
      },
      "highlightBottom": {
        "bottom": "22%", "right": "20%", "width": "16%", "height": "10%",
        "background": "rgba(255,255,255,0.2)", "blur": "1px", "rotation": "25deg"
      }
    }
  },

  "eyes": {
    "count": 2,
    "gap": "12px",
    "default": { "w": 11, "h": 19, "br": "6px" },
    "color": "white",
    "glow": "0 0 8px rgba(255,255,255,0.9), 0 0 16px rgba(255,255,255,0.4)",
    "containerPosition": { "top": "16%", "left": "10%", "width": "80%", "height": "50%" },
    "expressions": {
      "normal":     { "L": { "w": 11, "h": 19, "br": "6px" } },
      "lookLeft":   { "L": { "w": 11, "h": 19, "br": "6px", "tx": -4 } },
      "lookRight":  { "L": { "w": 11, "h": 19, "br": "6px", "tx": 4 } },
      "lookUp":     { "L": { "w": 11, "h": 19, "br": "6px", "ty": -5 } },
      "lookDown":   { "L": { "w": 11, "h": 15, "br": "6px", "ty": 4 } },
      "squint":     { "L": { "w": 12, "h": 6, "br": "4px", "ty": 1 } },
      "talking":    { "L": { "w": 10, "h": 17, "br": "5px" } },
      "talkBig":    { "L": { "w": 12, "h": 20, "br": "6px" } },

      "blink":      { "L": { "w": 12, "h": 3, "br": "3px" }, "speed": "snap" },

      "halfBlink":  { "L": { "w": 11, "h": 10, "br": "5px" }, "speed": "fast" },
      "surprised":  { "L": { "w": 13, "h": 21, "br": "7px" }, "speed": "fast" },
      "wow":        { "L": { "w": 16, "h": 16, "br": "8px" }, "speed": "fast" },
      "sparkle":    { "L": { "w": 12, "h": 12, "br": "3px", "rot": 45 }, "speed": "fast" },
      "wink":       { "L": { "w": 13, "h": 7, "br": "7px 7px 3px 3px", "ty": 1 }, "R": { "w": 11, "h": 19, "br": "6px" }, "speed": "fast" },
      "winkR":      { "L": { "w": 11, "h": 19, "br": "6px" }, "R": { "w": 13, "h": 7, "br": "7px 7px 3px 3px", "ty": 1 }, "speed": "fast" },
      "dizzy":      { "L": { "w": 10, "h": 10, "br": "5px", "rot": 25, "tx": -2 }, "R": { "w": 10, "h": 10, "br": "5px", "rot": -25, "tx": 2 }, "speed": "fast" },
      "cross":      { "L": { "w": 10, "h": 3, "br": "2px", "rot": 30 }, "R": { "w": 10, "h": 3, "br": "2px", "rot": -30 }, "speed": "fast" },
      "flattered":  { "L": { "w": 14, "h": 20, "br": "7px", "sy": 1.05 }, "speed": "fast" },
      "nervous":    { "L": { "w": 9, "h": 14, "br": "5px", "ty": 1, "sx": 0.9 }, "speed": "fast" },

      "happy":      { "L": { "w": 13, "h": 7, "br": "7px 7px 3px 3px", "ty": 1 }, "speed": "smooth" },
      "superHappy": { "L": { "w": 15, "h": 5, "br": "8px 8px 3px 3px", "ty": 1, "sx": 1.1 }, "speed": "smooth" },
      "giggle":     { "L": { "w": 13, "h": 7, "br": "7px 7px 3px 3px", "ty": 1, "rot": -8 }, "R": { "w": 13, "h": 7, "br": "7px 7px 3px 3px", "ty": 1, "rot": 8 }, "speed": "smooth" },
      "curious":    { "L": { "w": 9, "h": 16, "br": "5px", "ty": -1 }, "R": { "w": 13, "h": 21, "br": "7px", "ty": -1 }, "speed": "smooth" },
      "thinking":   { "L": { "w": 10, "h": 17, "br": "5px", "ty": -3 }, "speed": "smooth" },
      "hmm":        { "L": { "w": 11, "h": 16, "br": "5px", "ty": -1, "rot": 8 }, "R": { "w": 9, "h": 13, "br": "5px", "ty": 0, "rot": -8 }, "speed": "smooth" },
      "sad":        { "L": { "w": 10, "h": 16, "br": "5px", "ty": 3, "sy": 0.9 }, "speed": "smooth" },
      "angry":      { "L": { "w": 12, "h": 14, "br": "3px 6px 6px 3px", "ty": -2, "rot": -12 }, "R": { "w": 12, "h": 14, "br": "6px 3px 3px 6px", "ty": -2, "rot": 12 }, "speed": "smooth" },
      "love":       { "L": { "w": 14, "h": 13, "br": "7px 1px 7px 1px", "rot": 45, "sx": 1.1 }, "speed": "smooth" },
      "smug":       { "L": { "w": 11, "h": 7, "br": "6px 6px 3px 3px", "ty": 1 }, "R": { "w": 9, "h": 15, "br": "5px", "tx": 3 }, "speed": "smooth" },
      "confused":   { "L": { "w": 11, "h": 19, "br": "6px", "ty": -2 }, "R": { "w": 9, "h": 12, "br": "5px", "ty": 2, "rot": 15 }, "speed": "smooth" },
      "softSmile":  { "L": { "w": 12, "h": 9, "br": "6px 6px 3px 3px", "ty": 1 }, "speed": "smooth" },
      "focus":      { "L": { "w": 9, "h": 18, "br": "4px", "ty": -1 }, "speed": "smooth" },
      "pout":       { "L": { "w": 10, "h": 11, "br": "5px", "ty": 2, "sy": 0.85 }, "speed": "smooth" },
      "peekL":      { "L": { "w": 11, "h": 6, "br": "4px", "ty": 1 }, "R": { "w": 10, "h": 17, "br": "5px", "tx": -3 }, "speed": "smooth" },
      "peekR":      { "L": { "w": 10, "h": 17, "br": "5px", "tx": 3 }, "R": { "w": 11, "h": 6, "br": "4px", "ty": 1 }, "speed": "smooth" },
      "mischief":   { "L": { "w": 13, "h": 14, "br": "7px", "rot": -5, "ty": -1 }, "R": { "w": 9, "h": 10, "br": "5px", "rot": 10, "ty": 1 }, "speed": "smooth" },
      "worried":    { "L": { "w": 11, "h": 16, "br": "5px", "ty": 1, "rot": 5 }, "R": { "w": 11, "h": 16, "br": "5px", "ty": 1, "rot": -5 }, "speed": "smooth" },
      "sly":        { "L": { "w": 10, "h": 14, "br": "5px", "tx": 3, "rot": -6 }, "R": { "w": 12, "h": 8, "br": "6px 6px 3px 3px", "tx": 3, "ty": 1 }, "speed": "smooth" },

      "sleepy":     { "L": { "w": 12, "h": 4, "br": "4px", "ty": 2 }, "speed": "slow" },
      "drowsy":     { "L": { "w": 11, "h": 10, "br": "5px", "ty": 1 }, "speed": "slow" },
      "dead":       { "L": { "w": 10, "h": 3, "br": "2px", "ty": 3 }, "speed": "slow" },
      "content":    { "L": { "w": 13, "h": 8, "br": "7px 7px 4px 4px", "ty": 0, "sx": 1.05 }, "speed": "slow" },
      "bliss":      { "L": { "w": 14, "h": 5, "br": "7px 7px 2px 2px", "ty": 1, "sx": 1.1 }, "speed": "slow" },

      "daydream":   { "L": { "w": 13, "h": 20, "br": "7px", "ty": -3, "sx": 0.95 }, "speed": "drift" },
      "blank":      { "L": { "w": 8, "h": 15, "br": "4px" }, "speed": "drift" }
    }
  },

  "decorations": {
    "blush": {
      "enabled": true,
      "color": "rgba(255,130,130,0.25)",
      "size": { "width": 14, "height": 8 },
      "blur": 3,
      "positions": [
        { "top": "58%", "left": "8%" },
        { "top": "58%", "right": "8%" }
      ]
    },
    "bubbles": {
      "enabled": true,
      "items": [
        { "size": 5, "left": "-5px", "top": "60%", "duration": "5s", "delay": "0s" },
        { "size": 3, "right": "-4px", "top": "40%", "duration": "6.5s", "delay": "2s" }
      ]
    },
    "particles": {
      "colors": ["#ff6b6b", "#ffa07a", "#ffb347", "#ff69b4", "#fff", "#ffd700"],
      "count": 8,
      "distance": { "min": 15, "max": 40 },
      "sizeRange": { "min": 2, "max": 5 }
